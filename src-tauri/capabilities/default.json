{
  "$schema": "https://schema.tauri.app/config/2/capability.json",
  "identifier": "default",
  "description": "BlameBot default capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-is-visible",
    "core:window:allow-set-focus",
    "core:event:allow-emit",
    "core:event:allow-listen",
    "opener:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "shell:allow-open",
    "fs:allow-read-text-file",
    "fs:allow-read-dir",
    "fs:allow-write-text-file",
    "fs:allow-create",
    "fs:allow-exists",
    "fs:allow-stat",
    "fs:allow-mkdir",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister",
    "global-shortcut:allow-is-registered",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "run-powershell",
          "cmd": "powershell",
          "args": [
            "-NoProfile",
            "-ExecutionPolicy",
            "Bypass",
            "-Command",
            { "validator": ".*" }
          ]
        },
        {
          "name": "run-cmd",
          "cmd": "cmd",
          "args": [
            "/C",
            { "validator": ".*" }
          ]
        },
        {
          "name": "run-sh",
          "cmd": "sh",
          "args": [
            "-c",
            { "validator": ".*" }
          ]
        },
        {
          "name": "run-bash",
          "cmd": "bash",
          "args": [
            "-c",
            { "validator": ".*" }
          ]
        },
        {
          "name": "git",
          "cmd": "git",
          "args": [{ "validator": ".*" }]
        },
        {
          "name": "npm",
          "cmd": "npm",
          "args": [{ "validator": ".*" }]
        },
        {
          "name": "npx",
          "cmd": "npx",
          "args": [{ "validator": ".*" }]
        },
        {
          "name": "npm-cmd",
          "cmd": "npm.cmd",
          "args": [{ "validator": ".*" }]
        },
        {
          "name": "npx-cmd",
          "cmd": "npx.cmd",
          "args": [{ "validator": ".*" }]
        },
        {
          "name": "node",
          "cmd": "node",
          "args": [{ "validator": ".*" }]
        },
        {
          "name": "python",
          "cmd": "python",
          "args": [{ "validator": ".*" }]
        },
        {
          "name": "cargo",
          "cmd": "cargo",
          "args": [{ "validator": ".*" }]
        }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "run-powershell",
          "cmd": "powershell",
          "args": [
            "-NoProfile",
            "-ExecutionPolicy",
            "Bypass",
            "-Command",
            { "validator": ".*" }
          ]
        },
        {
          "name": "run-cmd",
          "cmd": "cmd",
          "args": [
            "/C",
            { "validator": ".*" }
          ]
        },
        {
          "name": "run-sh",
          "cmd": "sh",
          "args": [
            "-c",
            { "validator": ".*" }
          ]
        },
        {
          "name": "run-bash",
          "cmd": "bash",
          "args": [
            "-c",
            { "validator": ".*" }
          ]
        },
        {
          "name": "git",
          "cmd": "git",
          "args": [{ "validator": ".*" }]
        },
        {
          "name": "npm",
          "cmd": "npm",
          "args": [{ "validator": ".*" }]
        },
        {
          "name": "npx",
          "cmd": "npx",
          "args": [{ "validator": ".*" }]
        },
        {
          "name": "npm-cmd",
          "cmd": "npm.cmd",
          "args": [{ "validator": ".*" }]
        },
        {
          "name": "npx-cmd",
          "cmd": "npx.cmd",
          "args": [{ "validator": ".*" }]
        },
        {
          "name": "node",
          "cmd": "node",
          "args": [{ "validator": ".*" }]
        },
        {
          "name": "python",
          "cmd": "python",
          "args": [{ "validator": ".*" }]
        },
        {
          "name": "cargo",
          "cmd": "cargo",
          "args": [{ "validator": ".*" }]
        }
      ]
    }
  ]
}
